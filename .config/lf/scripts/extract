#!/usr/bin/env sh

script_dir=$(dirname -- "$0")
. "$script_dir/lib"

archive_dir() {
  dirname -- "$1"
}

archive_base() {
  name=$(basename -- "$1")
  case "$name" in
  *.tar.gz | *.tar.bz2 | *.tar.xz | *.tar.zst)
    name=${name%.*}
    name=${name%.*}
    ;;
  *)
    name=${name%.*}
    ;;
  esac
  printf '%s\n' "$name"
}

unique_dir() {
  base=$1
  candidate=$base
  n=1
  while [ -e "$candidate" ]; do
    candidate="$base-$n"
    n=$((n + 1))
  done
  printf '%s\n' "$candidate"
}

extract_zip() {
  require_command unzip "Install unzip."
  unzip -q -- "$1" -d "$2"
}

extract_rar() {
  if command -v unrar >/dev/null 2>&1; then
    unrar x -o+ "$1" "$2/"
    return $?
  fi
  if command -v unar >/dev/null 2>&1; then
    unar -o "$2" "$1"
    return $?
  fi
  die "unrar or unar is not installed"
}

extract_7z() {
  require_command 7z "Install p7zip."
  7z x "-o$2" "$1" >/dev/null
}

extract_tar() {
  require_command tar "Install tar."
  tar -x"$3"f "$1" -C "$2"
}

extract_tar_zstd() {
  require_command tar "Install tar."
  tar --zstd -xf "$1" -C "$2"
}

extract_plain_compressed() {
  require_command "$1" "Install $1."
  "$1" -dc -- "$2" >"$3"
}

extract_one() {
  file=$1

  if [ ! -f "$file" ]; then
    warn "Warning: not a regular file, skipping: $file"
    return 1
  fi

  wanted_dir="$(archive_dir "$file")/$(archive_base "$file")"
  dest_dir=$(unique_dir "$wanted_dir")

  if ! mkdir -p -- "$dest_dir"; then
    warn "Warning: could not create destination dir: $dest_dir"
    return 1
  fi

  case "$file" in
  *.zip) extract_zip "$file" "$dest_dir" ;;
  *.rar) extract_rar "$file" "$dest_dir" ;;
  *.7z) extract_7z "$file" "$dest_dir" ;;
  *.tar.gz | *.tgz) extract_tar "$file" "$dest_dir" z ;;
  *.tar.bz2 | *.tbz2) extract_tar "$file" "$dest_dir" j ;;
  *.tar.xz | *.txz) extract_tar "$file" "$dest_dir" J ;;
  *.tar.zst) extract_tar_zstd "$file" "$dest_dir" ;;
  *.tar) extract_tar "$file" "$dest_dir" "" ;;
  *.gz) extract_plain_compressed gzip "$file" "$dest_dir/$(archive_base "$file")" ;;
  *.bz2) extract_plain_compressed bzip2 "$file" "$dest_dir/$(archive_base "$file")" ;;
  *.xz) extract_plain_compressed xz "$file" "$dest_dir/$(archive_base "$file")" ;;
  *)
    warn "Warning: unsupported archive format, skipping: $file"
    return 1
    ;;
  esac
  extract_status=$?

  if [ "$extract_status" -ne 0 ]; then
    warn "Warning: extraction failed for: $file"
    return 1
  fi
  return 0
}

main() {
  require_at_least_one_arg "$#" "Usage: $(basename -- "$0") ARCHIVE [ARCHIVE...]"

  fail_count=0
  for file in "$@"; do
    if ! extract_one "$file"; then
      fail_count=$((fail_count + 1))
    fi
  done

  if [ "$fail_count" -gt 0 ]; then
    die "$fail_count archive(s) failed to extract"
  fi
}

main "$@"
