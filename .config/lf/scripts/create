#!/bin/env sh
#
# create.sh — smart file/dir creator for lf.
#
# Rules:
#   - trailing "/" -> directory
#   - otherwise    -> file (parent dirs auto-created)
#
# Usage: create.sh <path>
die() {
  echo "create.sh: $1" >&2
  exit 1
}

is_forced_dir() {
  case "$1" in
  */) return 0 ;;
  *) return 1 ;;
  esac
}

ensure_parent_dir() {
  parent=$(dirname "$1")
  [ "$parent" = "." ] && return 0
  mkdir -p "$parent" || die "failed to create parent directory '$parent'"
}

make_dir() {
  mkdir -p "$1" || die "failed to create directory '$1'"
}

make_file() {
  ensure_parent_dir "$1"
  touch "$1" || die "failed to create file '$1'"
}

validate_target() {
  [ -n "$1" ] || die "no target given"
  [ -e "$1" ] && die "'$1' already exists"
}

main() {
  target="$1"
  validate_target "$target"
  if is_forced_dir "$target"; then
    make_dir "$target"
  else
    make_file "$target"
  fi
}

main "$1"
