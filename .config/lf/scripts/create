#!/usr/bin/env sh

script_dir=$(dirname -- "$0")
. "$script_dir/lib"

script_dir=$(dirname -- "$0")
. "$script_dir/lib"

ends_with_slash() {
  case "$1" in
  */) return 0 ;;
  *) return 1 ;;
  esac
}

ensure_parent_dir() {
  parent=$(dirname -- "$1")
  if [ "$parent" = "." ] || [ "$parent" = "/" ]; then
    return 0
  fi
  if ! mkdir -p -- "$parent"; then
    die "Failed to create parent directory: $parent"
  fi
}

make_dir() {
  if ! mkdir -p -- "$1"; then
    die "Failed to create directory: $1"
  fi
}

make_file() {
  ensure_parent_dir "$1"
  if ! touch -- "$1"; then
    die "Failed to create file: $1"
  fi
}

validate_target() {
  if [ -e "$1" ]; then
    die "'$1' already exists"
  fi
}

main() {
  require_at_least_one_arg "$#" "Usage: $(basename -- "$0") NAME"
  target=$1

  validate_target "$target"

  if ends_with_slash "$target"; then
    make_dir "$target"
  else
    make_file "$target"
  fi
}

main "$@"
