#!/usr/bin/env sh

die() {
  printf '%s\n' "$*" >&2
  exit 1
}

warn() {
  printf '%s\n' "$*" >&2
}

require_command() {
  cmd_name=$1
  hint=$2
  if command -v "$cmd_name" >/dev/null 2>&1; then
    return 0
  fi
  if [ -n "$hint" ]; then
    die "'$cmd_name' is not installed. $hint"
  fi
  die "'$cmd_name' is not installed."
}

require_at_least_one_arg() {
  count=$1
  usage=$2
  if [ "$count" -lt 1 ]; then
    die "$usage"
  fi
}
