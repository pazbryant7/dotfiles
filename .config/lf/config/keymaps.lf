map D trash
map a create
map x extract

map W wallpaper
map R bulk-rename

map <c-n> drag
map <a-c> fzf-cd
map <c-t> fzf-search

map Z zoxide
map zd cd-back
map zp copy-path
map zz push :zoxide<space>

map gh cd ~
map gc cd ~/.config
map gd cd ~/Downloads
map gm cd /run/media
map gt cd ~/.local/share/Trash/files
