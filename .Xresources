Xft.rgba: rgb
Xft.hinting: 1
Xft.antialias: 1
Xft.hintstyle: hintslight
Xft.lcdfilter: lcddefault


! mocha
*.background: #1e1e2e
*.foreground: #ffffff
*.cursorColor: #4E445F

*.color0: #45475a
*.color8: #585b70
*.color1: #f38ba8
*.color9: #f38ba8
*.color2: #a6e3a1
*.color10: #a6e3a1
*.color3: #f9e2af
*.color11: #f9e2af
*.color4: #89b4fa
*.color12: #89b4fa
*.color5: #f5c2e7
*.color13: #f5c2e7
*.color6: #94e2d5
*.color14: #94e2d5
*.color7: #bac2de
*.color15: #a6adc8

st.alpha: 0.85
st.chscale: 1.00
st.cwscale: 0.90
st.borderpx: 0px

! Annotation mono regular
st.currentfont: 0

! Nsxiv specific
Nsxiv.window.background: #1e1e2e
Nsxiv.window.foreground: #ffffff

! DWM specific configurations
dwm.selbgcolor: #4E445F
dwm.selfgcolor: #ffffff
dwm.normbgcolor: #000000
dwm.normfgcolor: #817f7f
dwm.selbordercolor: #4E445F
dwm.normbordercolor: #817f7f
