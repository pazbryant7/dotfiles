# ~/.editorconfig
# Global editor config - applies to ALL projects
# Used as fallback when project-specific config doesn't specify

root = false

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.{yml,yaml}]
indent_size = 2

[Makefile]
indent_style = tab

[*.py]
indent_size = 4

[*.go]
indent_style = tab

[*.{c,cpp,h,hpp}]
indent_size = 4

[*.{sh,bash,zsh}]
indent_size = 2

[*.lua]
indent_size = 2
