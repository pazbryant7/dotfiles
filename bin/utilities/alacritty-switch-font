#!/bin/sh

STATE_FILE="${XDG_RUNTIME_DIR:-/tmp}/alacritty_font_state"

# Recursive first (states 0-2), then Annotation Mono (states 3-5)
# normal_family|normal_style|bold_family|bold_style
STATES="
Recursive Mn Csl St|Regular|Recursive Mn Csl St Med|Medium
Recursive Mn Csl St Med|Medium|Recursive Mn Csl St SmB|SemiBold
Recursive Mn Csl St SmB|SemiBold|Recursive Mn Csl St|Bold
Recursive Mn Csl St|Bold|Recursive Mn Csl St|Bold
Annotation Mono|Medium|Annotation Mono|DemiBold
Annotation Mono|DemiBold|Annotation Mono|Bold
Annotation Mono|Bold|Annotation Mono|ExtraBold
Annotation Mono|ExtraBold|Annotation Mono|ExtraBold
"
TOTAL=8

read_state() {
  cat "$STATE_FILE" 2>/dev/null || echo 0
}

write_state() {
  echo "$1" >"$STATE_FILE"
}

next_state() {
  echo $((($1 + 1) % TOTAL))
}

state_at() {
  echo "$STATES" | grep -v '^$' | sed -n "$(($1 + 1))p"
}

field() { echo "$1" | cut -d'|' -f"$2"; }

apply_font() {
  alacritty msg config \
    "font.normal.family=\"$1\"" \
    "font.normal.style=\"$2\"" \
    "font.bold.family=\"$3\"" \
    "font.bold.style=\"$4\""
}

main() {
  current=$(read_state)
  entry=$(state_at "$current")

  apply_font "$(field "$entry" 1)" "$(field "$entry" 2)" "$(field "$entry" 3)" \
    "$(field "$entry" 4)"

  write_state "$(next_state "$current")"
}
main
