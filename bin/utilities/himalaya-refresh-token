#!/usr/bin/env sh
# himalaya-refresh-token
# Uses the stored refresh token to obtain a new access token.
# If this fails, your refresh token has expired — run the full auth flow again.

TOKEN_URL="https://login.microsoftonline.com/common/oauth2/v2.0/token"
SCOPE="https://outlook.office.com/IMAP.AccessAsUser.All https://outlook.office.com/SMTP.Send offline_access"

# client-id is not a secret — matches what is in himalaya config plaintext
CLIENT_ID="006fe53f-dce4-45e1-9097-91b937b46caf"

# gopass store mount for passphrase-less local secrets
GOPASS_STORE="local"
GOPASS_BASE="${GOPASS_STORE}/azure/personal/himalaya"

# --- functions ---
die() {
	printf 'error: %s\n' "$1" >&2
	exit 1
}

read_secret() {
	key="$1"
	value=$(gopass -o "$key" 2>/dev/null) || die "could not read '$key' from gopass"
	[ -n "$value" ] || die "empty value for '$key' in gopass"
	printf '%s' "$value"
}

request_new_tokens() {
	client_secret="$1"
	refresh_token="$2"

	response=$(curl -s -X POST "$TOKEN_URL" \
		-H "Content-Type: application/x-www-form-urlencoded" \
		--data-urlencode "client_id=${CLIENT_ID}" \
		--data-urlencode "client_secret=${client_secret}" \
		--data-urlencode "grant_type=refresh_token" \
		--data-urlencode "refresh_token=${refresh_token}" \
		--data-urlencode "scope=${SCOPE}") || die "curl failed — check your internet connection"

	[ -n "$response" ] || die "empty response from token endpoint"

	error=$(printf '%s' "$response" | jq -r '.error // empty')
	if [ -n "$error" ]; then
		error_description=$(printf '%s' "$response" | jq -r '.error_description // empty')
		die "token endpoint error: ${error}: ${error_description}"
	fi

	printf '%s' "$response"
}

parse_token() {
	response="$1"
	field="$2"
	value=$(printf '%s' "$response" | jq -r ".$field // empty")
	[ -n "$value" ] || die "could not parse '$field' — refresh token may have expired, run the full auth flow again"
	printf '%s' "$value"
}

store_secret() {
	key="$1"
	value="$2"
	printf '%s' "$value" | gopass insert -f "$key" 2>/dev/null || die "could not store '$key' in gopass"
}

main() {
	client_secret=$(read_secret "${GOPASS_BASE}/secret") || exit 1
	refresh_token=$(read_secret "${GOPASS_BASE}/refresh-token") || exit 1

	response=$(request_new_tokens "$client_secret" "$refresh_token") || exit 1

	access_token=$(parse_token "$response" "access_token") || exit 1
	new_refresh_token=$(parse_token "$response" "refresh_token") || exit 1

	store_secret "${GOPASS_BASE}/access-token" "$access_token" || exit 1
	store_secret "${GOPASS_BASE}/refresh-token" "$new_refresh_token" || exit 1

	printf 'tokens refreshed successfully\n'
}

main "$@"
