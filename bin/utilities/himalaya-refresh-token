#!/usr/bin/env sh
# himalaya-refresh-token
# Uses the stored refresh token to obtain a new access token.
# If this fails, your refresh token has expired — run the full auth flow again.

TOKEN_URL="https://login.microsoftonline.com/common/oauth2/v2.0/token"
SCOPE="https://outlook.office.com/IMAP.AccessAsUser.All https://outlook.office.com/SMTP.Send offline_access"

# --- functions ---

die() {
	printf 'error: %s\n' "$1" >&2
	exit 1
}

check_dependencies() {
	for cmd in curl jq gopass; do
		command -v "$cmd" >/dev/null 2>&1 || die "'$cmd' is required but not installed"
	done
}

read_secret() {
	key="$1"
	value=$(gopass -o "$key" 2>/dev/null)
	if [ -z "$value" ]; then
		die "could not read '$key' from gopass"
	fi
	printf '%s' "$value"
}

request_new_tokens() {
	client_id="$1"
	client_secret="$2"
	refresh_token="$3"

	response=$(curl -s -X POST "$TOKEN_URL" \
		-H "Content-Type: application/x-www-form-urlencoded" \
		--data-urlencode "client_id=${client_id}" \
		--data-urlencode "client_secret=${client_secret}" \
		--data-urlencode "grant_type=refresh_token" \
		--data-urlencode "refresh_token=${refresh_token}" \
		--data-urlencode "scope=${SCOPE}")

	if [ -z "$response" ]; then
		die "empty response from token endpoint — check your internet connection"
	fi

	printf '%s' "$response"
}

parse_token() {
	response="$1"
	field="$2"

	value=$(printf '%s' "$response" | jq -r ".$field // empty")

	if [ -z "$value" ]; then
		die "could not parse '$field' — refresh token may have expired, run the full auth flow again"
	fi

	printf '%s' "$value"
}

store_secret() {
	key="$1"
	value="$2"

	printf '%s' "$value" | gopass insert -f "$key" 2>/dev/null

	if [ $? -ne 0 ]; then
		die "could not store '$key' in gopass"
	fi
}

# --- main ---

check_dependencies

client_id=$(read_secret "azure/personal/himalaya/client-id")
client_secret=$(read_secret "azure/personal/himalaya/secret")
refresh_token=$(read_secret "azure/personal/himalaya/refresh-token")

response=$(request_new_tokens "$client_id" "$client_secret" "$refresh_token")

access_token=$(parse_token "$response" "access_token")
new_refresh_token=$(parse_token "$response" "refresh_token")

store_secret "azure/personal/himalaya/access-token" "$access_token"
store_secret "azure/personal/himalaya/refresh-token" "$new_refresh_token"

printf 'tokens refreshed successfully\n'
