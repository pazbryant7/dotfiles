#!/usr/bin/env sh

RECORDING_ICON="^c#FFFFFF^[REC]^d^"
RUNTIME_DIR="${XDG_RUNTIME_DIR:-/tmp}/screen_recorder"
PID_FILE="$RUNTIME_DIR/ffmpeg.pid"

is_recording() {
  [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null
}

main() {
  is_recording && printf "%s | " "$RECORDING_ICON"
}
main "$@"
