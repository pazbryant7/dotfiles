#!/bin/sh

BLOCK_DEVICE="/dev/sdb1"
MEDIA_DESTINATION="/run/media/bryant/tiagovault"
RSYNC_EXCLUDE_OPTS="*.sock
SingletonLock
SingletonSocket
SingletonCookie
Crashpad/
Local Cache/
Cache/
Code Cache/
GrShaderCache/
ShaderCache/
Service Worker/CacheStorage/
Service Worker/ScriptCache/
GPUCache/
DawnCache/
DawnGraphiteCache/
Media Cache/
VideoDecodeStats/
optimization_guide_prediction_model_downloads/
optimization_guide_model_cache/
tmp/
shared_proto_db/
Safe Browse/
user_data/
webrtc_event_logs/
segment_data/
system_certs/
.tmp
.log
.DS_Store
Thumbs.db
ehthumbs.db
desktop.ini
.fuse_hidden*
.swp"

MEDIA_SOURCES="$HOME/Documents/books
$HOME/Music
$HOME/.config/calibre
$HOME/.config/net.imput.helium
$HOME/.config/qBittorrent
$HOME/.config/BraveSoftware"

is_mounted() {
  mountpoint -q "$MEDIA_DESTINATION"
}

mount_disk() {
  if is_mounted; then
    printf '%s\n' "Info: Destination '$MEDIA_DESTINATION' is already a mount point."
    return 0
  fi

  printf '%s\n' "Info: Attempting to mount '$BLOCK_DEVICE'..."
  if udisksctl mount -b "$BLOCK_DEVICE"; then
    printf '%s\n' "Success: Mounted '$BLOCK_DEVICE' at '$MEDIA_DESTINATION'."
    return 0
  fi

  printf '%s\n' "Error: Failed to mount '$BLOCK_DEVICE'." >&2
  return 1
}

unmount_disk() {
  printf '%s\n' "Info: Attempting to unmount '$BLOCK_DEVICE'..."
  unmount_output=$(udisksctl unmount -b "$BLOCK_DEVICE" 2>&1)
  unmount_status=$?

  if [ "$unmount_status" -ne 0 ]; then
    printf '%s\n' "Error: Failed to unmount '$BLOCK_DEVICE'." >&2
    printf '%s\n' "udisksctl output: $unmount_output" >&2
    return 1
  fi

  if is_mounted; then
    printf '%s\n' "Warning: '$MEDIA_DESTINATION' still appears as a mount point. Please check manually." >&2
  fi

  printf '%s\n' "Success: '$BLOCK_DEVICE' has been unmounted."
  return 0
}

run_backup() {
  source_path="$1"
  exclude_file="$2"
  source_basename=$(basename "$source_path")
  target_name=$(printf '%s\n' "$source_basename" | tr '[:upper:]' '[:lower:]')
  error_log="/tmp/rsync_errors_$target_name.log"
  backup_dest="$MEDIA_DESTINATION/backups/$target_name"

  if ! mkdir -p "$backup_dest"; then
    printf '%s\n' "Error: Failed to create destination directory '$backup_dest'." >&2
    return 1
  fi

  printf '%s\n' "Backing up '$source_path' to '$backup_dest'..."

  if rsync -avL --delete --exclude-from="$exclude_file" "$source_path/" "$backup_dest/" 2>"$error_log"; then
    rm -f "$error_log"
    return 0
  fi

  printf "Error: rsync failed for source '%s'. See log for details:\n" "$source_path" >&2
  printf "  %s\n" "$error_log" >&2
  return 1
}

run_restore() {
  source_path="$1"
  exclude_file="$2"
  source_basename=$(basename "$source_path")
  target_name=$(printf '%s\n' "$source_basename" | tr '[:upper:]' '[:lower:]')
  error_log="/tmp/rsync_restore_errors_$target_name.log"
  backup_src="$MEDIA_DESTINATION/backups/$target_name"

  if [ ! -d "$backup_src" ]; then
    printf "Error: No backup found at '%s'. Skipping.\n" "$backup_src" >&2
    return 1
  fi

  if ! mkdir -p "$source_path"; then
    printf "Error: Failed to create restore destination '%s'.\n" "$source_path" >&2
    return 1
  fi

  printf '%s\n' "Restoring '$backup_src' to '$source_path'..."

  # --delete is intentionally omitted: files that exist locally but not in the
  # backup are kept rather than wiped. Pass --delete explicitly if you want a
  # mirror restore.
  if rsync -avL --exclude-from="$exclude_file" "$backup_src/" "$source_path/" 2>"$error_log"; then
    rm -f "$error_log"
    return 0
  fi

  printf "Error: rsync failed restoring '%s'. See log for details:\n" "$backup_src" >&2
  printf "  %s\n" "$error_log" >&2
  return 1
}

flush_disk_cache() {
  if sync; then
    return 0
  fi

  printf '%s\n' "Error: 'sync' command failed. Data may not be fully written to disk." >&2
  return 1
}

prompt_unmount() {
  printf '%s' "Would you like to unmount the disk $BLOCK_DEVICE (y/n)? "
  read -r response

  case "$response" in
  [yY])
    unmount_disk
    ;;
  [nN])
    return 0
    ;;
  *)
    printf '%s\n' "WARNING: Invalid response. Assuming 'n' (no unmount)." >&2
    return 0
    ;;
  esac
}

prompt_mode() {
  printf '%s\n' "What would you like to do?" >&2
  printf '%s\n' "  1) Backup" >&2
  printf '%s\n' "  2) Restore" >&2
  printf '%s' "Enter choice [1/2]: " >&2
  read -r mode_choice

  case "$mode_choice" in
  1) printf '%s\n' "backup" ;;
  2) printf '%s\n' "restore" ;;
  *)
    printf '%s\n' "Error: Invalid choice." >&2
    return 1
    ;;
  esac
}

prompt_source_selection() {
  printf '%s\n' "Select sources to restore (e.g. 1 3 4), or press Enter for all:" >&2

  i=1
  echo "$MEDIA_SOURCES" | while read -r src; do
    [ -z "$src" ] && continue
    printf '  %d) %s\n' "$i" "$src" >&2
    i=$((i + 1))
  done

  printf '%s' "Choice: " >&2
  read -r picks

  if [ -z "$picks" ]; then
    printf '%s\n' "$MEDIA_SOURCES"
    return 0
  fi

  echo "$MEDIA_SOURCES" | awk -v picks="$picks" '
    NF == 0 { next }
    {
      lines[NR] = $0
      max = NR
    }
    END {
      n = split(picks, sel, " ")
      for (k = 1; k <= n; k++) {
        idx = sel[k] + 0
        if (idx >= 1 && idx <= max)
          print lines[idx]
      }
    }
  '
}

process_sources() {
  exclude_file="$1"
  sources="$2"

  printf '%s\n' "$sources" | while read -r source; do
    [ -z "$source" ] && continue

    if [ ! -d "$source" ]; then
      printf "Warning: Source path '%s' does not exist or is not a directory. Skipping.\n" "$source" >&2
      continue
    fi

    if ! run_backup "$source" "$exclude_file"; then
      exit 1
    fi
  done

  return $?
}

process_restore() {
  exclude_file="$1"
  sources="$2"

  printf '%s\n' "$sources" | while read -r source; do
    [ -z "$source" ] && continue

    if ! run_restore "$source" "$exclude_file"; then
      exit 1
    fi
  done

  return $?
}

main() {
  mode=$(prompt_mode) || exit 1

  printf '%s\n' "=== Starting ${mode} process ==="

  if ! mount_disk; then
    printf '%s\n' "Critical Error: Disk mount failed. Aborting." >&2
    exit 1
  fi

  exclude_file=$(mktemp) || exit 1
  trap 'rm -f "$exclude_file"' EXIT INT TERM HUP
  printf '%s\n' "$RSYNC_EXCLUDE_OPTS" >"$exclude_file"

  case "$mode" in
  backup)
    if ! process_sources "$exclude_file" "$MEDIA_SOURCES"; then
      printf '%s\n' "Warning: One or more backup tasks failed." >&2
    fi
    ;;
  restore)
    selected=$(prompt_source_selection)
    printf '%s\n' "Warning: This will overwrite files in the selected locations. Continue? (y/n) "
    read -r confirm
    case "$confirm" in
    [yY]) ;;
    *)
      printf '%s\n' "Aborted."
      exit 0
      ;;
    esac

    if ! process_restore "$exclude_file" "$selected"; then
      printf '%s\n' "Warning: One or more restore tasks failed." >&2
    fi
    ;;
  esac

  if flush_disk_cache; then
    prompt_unmount
    printf '%s\n' "=== ${mode} has finished. ==="
    exit 0
  else
    printf '%s\n' "ERROR: Disk cache flush failed." >&2
    exit 1
  fi
}

main "$@"
