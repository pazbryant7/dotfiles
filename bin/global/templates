#!/usr/bin/env sh

BOILERPLATE_DIR="$HOME/Documents/github/templates/templates"

check_dependencies() {
	for cmd in fd fzf xclip; do
		command -v "$cmd" >/dev/null 2>&1 || {
			echo "Error: required command '$cmd' not found in PATH" >&2
			exit 1
		}
	done
}

select_templates() {
	fd --base-directory="$BOILERPLATE_DIR" --hidden --type=file --exclude="*.md" |
		fzf --multi --preview "cat $BOILERPLATE_DIR/{}" \
			--preview-window=right:60% \
			--header="Select template(s) (Tab to multi-select, ESC to exit)"
}

resolve_path() {
	printf '%s/%s' "$BOILERPLATE_DIR" "$1"
}

validate_template() {
	[ -f "$1" ] || {
		echo "Error: Template file not found: $1" >&2
		exit 1
	}
}

collect_contents() {
	while IFS= read -r relative_path; do
		[ -z "$relative_path" ] && continue
		full_path=$(resolve_path "$relative_path")
		validate_template "$full_path"
		cat "$full_path"
		printf '\n'
	done
}

copy_to_clipboard() {
	xclip -selection clipboard
}

notify_success() {
	printf 'Copied %s template(s) to the clipboard\n' "$1"
}

main() {
	check_dependencies

	selected_templates=$(select_templates)
	[ -z "$selected_templates" ] && exit 1

	template_count=$(printf '%s\n' "$selected_templates" | grep -c .)

	printf '%s\n' "$selected_templates" | collect_contents | copy_to_clipboard

	notify_success "$template_count"
}

main
