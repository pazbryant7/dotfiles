#!/usr/bin/env sh
# bulkrename - mass rename/move files or directories using $EDITOR
#
# Usage:
#   bulkrename path1 path2 ...
#   fd -t f . | bulkrename
#   find . -maxdepth 1 -mindepth 1 | bulkrename
#
# POSIX sh. No arrays: paths are kept one-per-line in temp files.
# No shell option flags: every command that can fail is checked explicitly.

TMPDIR_=""
ORIG_FILE=""
NAMES_FILE=""

die() {
  echo "bulkrename: $1" >&2
  cleanup
  exit 1
}

cleanup() {
  if [ -n "$TMPDIR_" ]; then
    rm -rf "$TMPDIR_"
  fi
}

# Collect paths from args, or from stdin if piped, into $ORIG_FILE.
gather_paths() {
  if [ "$#" -gt 0 ]; then
    printf '%s\n' "$@" >"$ORIG_FILE" || die "could not write to temp file"
  elif [ ! -t 0 ]; then
    cat >"$ORIG_FILE" || die "could not read from stdin"
  fi

  if [ ! -s "$ORIG_FILE" ]; then
    die "no input (pass paths as args or pipe them in)"
  fi
}

# Copy the path list and open it in $EDITOR for editing.
edit_names() {
  cp "$ORIG_FILE" "$NAMES_FILE" || die "could not create editable copy"

  editor="$EDITOR"
  if [ -z "$editor" ]; then
    editor="nvim"
  fi

  "$editor" "$NAMES_FILE" || die "editor exited with an error"
}

# Refuse to proceed if lines were added/removed, or if two lines
# now collide on the same target name.
validate() {
  orig_count=$(wc -l <"$ORIG_FILE")
  new_count=$(wc -l <"$NAMES_FILE")

  if [ "$orig_count" -ne "$new_count" ]; then
    die "line count changed ($orig_count -> $new_count); don't add/remove lines, nothing renamed"
  fi

  dupe=$(sort "$NAMES_FILE" | uniq -d)
  if [ -n "$dupe" ]; then
    echo "bulkrename: duplicate target name(s), aborting:" >&2
    echo "$dupe" >&2
    cleanup
    exit 1
  fi
}

# Walk both files in lockstep and perform the renames/moves.
do_rename() {
  renamed=0
  while IFS= read -r old <&3 && IFS= read -r new <&4; do
    if [ -z "$new" ]; then
      continue
    fi
    if [ "$old" = "$new" ]; then
      continue
    fi
    if [ -e "$new" ]; then
      echo "bulkrename: skip '$old' -> '$new' (target exists)" >&2
      continue
    fi

    newdir=$(dirname -- "$new")
    if [ ! -d "$newdir" ]; then
      mkdir -p -- "$newdir" || {
        echo "bulkrename: skip '$old' -> '$new' (could not create '$newdir')" >&2
        continue
      }
    fi

    if mv -- "$old" "$new"; then
      echo "renamed: $old -> $new"
      renamed=$((renamed + 1))
    else
      echo "bulkrename: failed to rename '$old' -> '$new'" >&2
    fi
  done 3<"$ORIG_FILE" 4<"$NAMES_FILE"

  echo "bulkrename: $renamed item(s) renamed/moved."
}

main() {
  TMPDIR_=$(mktemp -d) || die "could not create temp directory"
  trap cleanup 0 1 2 15
  ORIG_FILE="$TMPDIR_/orig"
  NAMES_FILE="$TMPDIR_/names"

  gather_paths "$@"
  edit_names
  validate
  do_rename
}

main "$@"
