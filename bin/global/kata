#!/usr/bin/env sh

practice_dir="$HOME/Documents/github/temp/kata"
dirs="$HOME/Documents/github/leetcode
$practice_dir"

lower() {
  printf "%s" "$1" | tr '[:upper:]' '[:lower:]'
}

name() {
  lower "$(basename "$1")"
}

die() {
  printf "%s\n" "$1" >&2
  exit 1
}

in_tmux() {
  [ -n "$TMUX" ]
}

new_session() {
  "$HOME/bin/global/neww" "$1"
}

new_window() {
  tmux new-window -t "$1" -c "$2"
}

get_index_type() {
  case "$1" in
  js) printf "index.ts" ;;
  py) printf "index.py" ;;
  cpp) printf "index.cpp" ;;
  rs) printf "index.rs" ;;
  go) printf "index.go" ;;
  *) die "unknown language: $1" ;;
  esac
}

open_index() {
  file=$(get_index_type "$2") || die "cannot get file type: $2"
  tmux send-keys -t "$1" "KATA=1 nvim $file" Enter
}

ensure_dir() {
  [ -d "$1" ] || mkdir -p "$1" || die "cannot create directory: $1"
}

switch_to() {
  tmux switch-client -t "$1"
}

exist_session() {
  tmux has-session -t="$1" 2>/dev/null
}

in_practice() {
  [ "$1" = "$practice_dir" ]
}

start_practicing() {
  sname="$1"
  dir="$2"
  lang="$3"
  new_window "$sname" "$dir" || die "cannot create new window"
  open_index "$sname" "$lang" || die "cannot open index"
}

setup() {
  dir="$1"
  lang="$2"
  sname=$(name "$dir") || die "cannot derive name from: $dir"

  if exist_session "$sname"; then
    in_practice "$dir" || return 0
    switch_to "$sname"
    return 0
  fi

  new_session "$dir" || die "cannot create session for: $dir"
  in_practice "$dir" && start_practicing "$sname" "$dir" "$lang"
}

workspace() {
  ensure_dir "$practice_dir"
  for dir in $dirs; do
    setup "$dir" "$1"
  done
}

main() {
  lang="${1:-js}"
  if in_tmux; then
    workspace "$lang"
  else
    printf "Not in a tmux session.\n" >&2
  fi
}

main "$@"
