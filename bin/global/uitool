#!/usr/bin/env sh

readonly XRESOURCES="$HOME/.Xresources"
readonly TMUX_CONFIG="$HOME/.tmux.conf"
readonly DUNSTRC="$HOME/.config/dunst/dunstrc"
readonly THEME_RASI="$HOME/.config/rofi/theme.rasi"
readonly STARSHIP_TOML="$HOME/.config/starship/starship.toml"
readonly ALACRITTY_CONFIG="$HOME/.config/alacritty/alacritty.toml"

HEX_PAT='#[0-9a-fA-F]\{6\}'

warn() {
  printf '%s\n' "Warning: $*" >&2
}

die() {
  printf '%s\n' "Error: $*" >&2
  exit 1
}

file_exists() {
  [ -f "$1" ]
}

update_line() {
  file="$1"
  pattern="$2"
  replacement="$3"
  file_exists "$file" || {
    warn "file not found: $file"
    return 1
  }
  escaped=$(printf '%s\n' "$replacement" | sed 's/[\/&]/\\&/g')
  sed -i "s|$pattern|$escaped|" "$file" || {
    warn "failed to update: $file"
    return 1
  }
}

update_starship_block_style() {
  file="$1"
  section="$2"
  color="$3"
  file_exists "$file" || return 1
  sed -i "/^\[$section\]/,/^\[/ s/style = \"bold $HEX_PAT\"/style = \"bold $color\"/" "$file" ||
    warn "failed to update starship section: $section"
}

select_color() {
  notify-send "Picking color"
  xcolor || die "failed to select color"
}

# Derive a brighter variant of a hex colour by scaling each RGB channel.
# Usage: derive_primary "#rrggbb" [factor]
# factor defaults to 1.4; channels are clamped to 255.
derive_primary() {
  raw="${1#'#'}"
  [ ${#raw} -eq 6 ] || die "derive_primary: invalid hex colour '$1'"
  factor="${2:-1.4}"
  printf '#%s' "$(printf '%s' "$raw" | awk -v factor="$factor" '
    {
      r = strtonum("0x" substr($0, 1, 2))
      g = strtonum("0x" substr($0, 3, 2))
      b = strtonum("0x" substr($0, 5, 2))
      r = int(r * factor); if (r > 255) r = 255
      g = int(g * factor); if (g > 255) g = 255
      b = int(b * factor); if (b > 255) b = 255
      printf "%02x%02x%02x", r, g, b
    }
  ')"
  printf '\n'
}

apply_rofi() {
  update_line "$THEME_RASI" \
    "background-alt:[[:space:]]*$HEX_PAT;" \
    "background-alt:$1;"
}

apply_tmux() {
  update_line "$TMUX_CONFIG" \
    "set-option -g status-style 'bg=#1e1e2e,fg=$HEX_PAT'" \
    "set-option -g status-style 'bg=#1e1e2e,fg=$1'"
}

apply_xresources() {
  update_line "$XRESOURCES" \
    "\*\.cursorColor:[[:space:]]*$HEX_PAT" \
    "*.cursorColor: $1"
  update_line "$XRESOURCES" \
    "dwm\.selbgcolor:[[:space:]]*$HEX_PAT" \
    "dwm.selbgcolor: $1"
  update_line "$XRESOURCES" \
    "dwm\.selbordercolor:[[:space:]]*$HEX_PAT" \
    "dwm.selbordercolor: $1"
}

apply_alacritty() {
  update_line "$ALACRITTY_CONFIG" \
    "cursor = \"$HEX_PAT\"" \
    "cursor = \"$1\""
}

apply_dunst() {
  update_line "$DUNSTRC" \
    "background = \"$HEX_PAT\"" \
    "background = \"$1\""
}

apply_starship() {
  update_line "$STARSHIP_TOML" \
    "success_symbol = \"\[󰁕\](bold $HEX_PAT)\"" \
    "success_symbol = \"[󰁕](bold $1)\""
  update_starship_block_style "$STARSHIP_TOML" "directory" "$1"
  update_starship_block_style "$STARSHIP_TOML" "git_branch" "$2"
}

reload_xresources() {
  file_exists "$XRESOURCES" || return 0
  xrdb -merge "$XRESOURCES" &&
    pgrep -x st | xargs -r kill -USR1 2>/dev/null || true
}

reload_dunst() {
  pgrep -x dunst >/dev/null || return 0
  pkill dunst
  while pgrep -x dunst >/dev/null; do sleep 0.05; done
  dunst &
}

reload_all() {
  reload_xresources &
  reload_dunst &
  pgrep -x qutebrowser >/dev/null && qutebrowser :config-source &
  pgrep -x dwm >/dev/null && xsetroot -name "fsignal:1" &
  pgrep tmux >/dev/null && tmux source-file "$TMUX_CONFIG" || true &
  wait
}

main() {
  accent="$1"
  primary="$2"
  [ -n "$accent" ] || accent=$(select_color)
  [ -n "$primary" ] || primary=$(derive_primary "$accent")
  apply_rofi "$accent" &
  apply_dunst "$accent" &
  apply_tmux "$accent" &
  apply_alacritty "$accent" &
  apply_xresources "$accent" &
  apply_starship "$accent" "$primary" &
  wait
  reload_all
  printf 'Theme updated: accent=%s primary=%s\n' "$accent" "$primary"
}

main "$@"
