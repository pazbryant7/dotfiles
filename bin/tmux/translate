#!/usr/bin/env python3
"""
translate.py — Spanish <-> English translator
Usage:
    translate.py en:es
    translate.py es:en
"""

from __future__ import annotations

import os
import select
import shutil
import subprocess
import sys
import termios
import time
import tty

# ── Constants ─────────────────────────────────────────────────────────────────

TRANS_OPTS = ["-verbose", "-no-warn"]

DIRECTIONS = {
    "en:es": "English → Spanish",
    "es:en": "Spanish → English",
}

SWAP = {
    "en:es": "es:en",
    "es:en": "en:es",
}

POST_MENU_TIMEOUT = 10


# ── Data types ────────────────────────────────────────────────────────────────


class History:
    """Append-only in-memory translation history with offset-based recall."""

    def __init__(self) -> None:
        self._entries: list[str] = []

    def add(self, entry: str) -> None:
        if not self._entries or self._entries[-1] != entry:
            self._entries.append(entry)

    def get(self, offset: int) -> str | None:
        """Return entry at offset from end (1 = last). None if out of range."""
        index = len(self._entries) - offset
        return self._entries[index] if 0 <= index < len(self._entries) else None


# ── Terminal helpers ──────────────────────────────────────────────────────────


def terminal_width() -> int:
    return shutil.get_terminal_size().columns


def separator() -> str:
    return "─" * terminal_width()


def clear_screen() -> None:
    print("\033[2J\033[H", end="", flush=True)


def print_centered(text: str) -> None:
    print(text.center(terminal_width()))


def print_separator() -> None:
    print(separator())


# ── External tool calls ───────────────────────────────────────────────────────


def run_translation(direction: str, query: str) -> None:
    subprocess.run(["trans", *TRANS_OPTS, direction, query], check=False)


def play_audio(direction: str, query: str) -> None:
    subprocess.run(
        ["trans", "-speak", direction, query],
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        check=False,
    )


def copy_to_clipboard(text: str) -> str:
    for tool, args in [
        ("pbcopy", ["pbcopy"]),
        ("xclip", ["xclip", "-selection", "clipboard"]),
        ("xsel", ["xsel", "--clipboard", "--input"]),
    ]:
        if shutil.which(tool):
            subprocess.run(args, input=text.encode(), check=False)
            return "📋  Copied to clipboard."
    return "⚠️   No clipboard tool found (pbcopy / xclip / xsel)."


# ── Raw character input ───────────────────────────────────────────────────────


def read_char(fd: int) -> str:
    return os.read(fd, 1).decode("utf-8", errors="replace")


def read_query(history: History) -> str | None:
    """
    Read a line with raw character handling.
    Supports backspace and up/down arrow history navigation.
    Returns None on Ctrl-C / Ctrl-D.
    """
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    buf = ""
    hist_offset = 0

    try:
        tty.setraw(fd)
        while True:
            ch = read_char(fd)

            if ch in ("\r", "\n"):
                sys.stdout.write("\n")
                sys.stdout.flush()
                return buf

            if ch in ("\x03", "\x04"):
                sys.stdout.write("\n")
                sys.stdout.flush()
                return None

            if ch in ("\x7f", "\x08"):
                if buf:
                    buf = buf[:-1]
                    sys.stdout.write("\b \b")
                    sys.stdout.flush()
                continue

            if ch == "\x1b":
                seq = read_char(fd) + read_char(fd)
                cols = terminal_width()

                if seq == "[A":  # Up
                    hist_offset += 1
                    entry = history.get(hist_offset)
                    if entry is None:
                        hist_offset -= 1
                    else:
                        buf = entry
                        sys.stdout.write(f"\r{' ' * cols}\r> {buf}")
                        sys.stdout.flush()

                elif seq == "[B":  # Down
                    if hist_offset > 0:
                        hist_offset -= 1
                    if hist_offset == 0:
                        buf = ""
                        sys.stdout.write(f"\r{' ' * cols}\r> ")
                    else:
                        entry = history.get(hist_offset)
                        if entry:
                            buf = entry
                            sys.stdout.write(f"\r{' ' * cols}\r> {buf}")
                    sys.stdout.flush()
                continue

            buf += ch
            sys.stdout.write(ch)
            sys.stdout.flush()

    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


def read_single_key(timeout: float) -> str:
    """Read one raw keypress with a timeout. Returns '' on timeout."""
    fd = sys.stdin.fileno()
    old = termios.tcgetattr(fd)
    try:
        tty.setraw(fd)
        ready, _, _ = select.select([sys.stdin], [], [], timeout)
        if not ready:
            return ""
        return os.read(fd, 1).decode("utf-8", errors="replace")
    finally:
        termios.tcsetattr(fd, termios.TCSADRAIN, old)


# ── Post-translation menu ─────────────────────────────────────────────────────


def post_menu(direction: str, query: str) -> None:
    """Show options after a translation. Auto-returns after timeout."""
    timeout = POST_MENU_TIMEOUT

    while True:
        print()
        print_separator()
        print(f"  [r] Replay audio   [c] Copy   [↵ / q] Next  (auto in {timeout}s)")
        print_separator()
        print("> ", end="", flush=True)

        ch = read_single_key(timeout)
        sys.stdout.write("\n")
        sys.stdout.flush()

        if ch in ("", "\r", "\n", "q", "\x03", "\x04"):
            break

        ch = ch.lower()

        if ch == "r":
            print("\n  🔊  Replaying audio...")
            play_audio(direction, query)
            timeout = POST_MENU_TIMEOUT  # reset

        elif ch == "c":
            print(f"\n  {copy_to_clipboard(query)}")
            timeout = POST_MENU_TIMEOUT

        else:
            print("  Unknown option.")


# ── Header ────────────────────────────────────────────────────────────────────


def print_header(direction: str) -> None:
    clear_screen()
    print()
    print_centered("━" * 40)
    print_centered(DIRECTIONS[direction])
    print_centered("[s] swap direction   [!] repeat   [q] quit")
    print_centered("━" * 40)
    print()


# ── Main loop ─────────────────────────────────────────────────────────────────


def main_loop(direction: str) -> None:
    history = History()
    last: str | None = None

    while True:
        print_header(direction)
        print("> ", end="", flush=True)

        raw = read_query(history)

        if raw is None:
            break

        stripped = raw.strip()

        if not stripped:
            continue

        lowered = stripped.lower()

        if lowered == "q":
            break

        if lowered == "s":
            direction = SWAP[direction]
            time.sleep(0.3)
            continue

        if lowered == "!":
            if last is None:
                print("  ⚠️   Nothing to repeat.")
                time.sleep(1)
                continue
            query = last
        else:
            query = stripped

        history.add(query)
        last = query

        print()
        print_separator()
        run_translation(direction, query)
        play_audio(direction, query)
        post_menu(direction, query)


# ── Entry point ───────────────────────────────────────────────────────────────


def main(argv: list[str]) -> int:
    if len(argv) < 2:
        print(f"Usage: {argv[0]} en:es | {argv[0]} es:en", file=sys.stderr)
        return 1

    direction = argv[1]
    if direction not in DIRECTIONS:
        print(f"Invalid direction '{direction}'. Use en:es or es:en.", file=sys.stderr)
        return 1

    try:
        main_loop(direction)
    except KeyboardInterrupt:
        pass

    print("\n👋  Goodbye.")
    return 0


if __name__ == "__main__":
    sys.exit(main(sys.argv))
