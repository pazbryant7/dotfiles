#!/usr/bin/env sh

SESSION_DIRS="
$HOME/Documents/github
$HOME/Documents/github/temp
"
NOTES_PATH="$HOME/Documents/github/notes
$HOME/Documents/github/youtube
"
NOTES_FILE="todo.md"

current_session() {
  tmux display-message -p '#S'
}

create_session() {
  tmux new-session -ds "$1" -c "$2"
}

switch_to() {
  tmux switch-client -t "$1"
}

notify() {
  tmux display-message "$1"
}

open_notes() {
  name="$1"
  path="$2"
  printf '%s\n' "$NOTES_PATH" | grep -Fxq "$path" || return
  tmux send-keys -t "$name" "${EDITOR:-nvim} $path/$NOTES_FILE" Enter
}

get_name() {
  basename "$1" | tr . _ | tr '[:upper:]' '[:lower:]'
}

pick_dirs() {
  # shellcheck disable=SC2086
  fd . --max-depth 1 --type d --type l --follow $SESSION_DIRS 2>/dev/null | fzf --multi
}

set_session() {
  path="$1"
  name="$2"

  curr_session="$(current_session)"

  if [ "$curr_session" != "$name" ]; then
    create_session "$name" "$path"
    open_notes "$name" "$path"
  else
    printf "%s ""Already in $name session"
  fi

  return 0
}

single() {
  path="$1"
  name="${2:-$(get_name "$path")}"
  set_session "$path" "$name" && switch_to "$name"
}

multi() {
  paths=$(pick_dirs)

  [ -z "$paths" ] && exit 1

  tmp=$(mktemp)

  printf '%s\n' "$paths" | while IFS= read -r path; do
    [ -z "$path" ] && continue
    name=$(get_name "$path")
    set_session "$path" "$name"
    printf '%s' "$name" >"$tmp"
  done

  last=$(cat "$tmp")
  rm -f "$tmp"
  [ -n "$last" ] && switch_to "$last"
}

main() {
  [ -n "$1" ] && {
    single "$@"
    return
  }
  multi
}

main "$@"
