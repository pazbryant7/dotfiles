#!/usr/bin/env sh

SESSION_DIRS="
$HOME/
$HOME/Documents/github
$HOME/Documents/github/temp
"

NOTES_PATH="$HOME/Documents/github/notes
$HOME/Documents/github/youtube
"

NOTES_FILE="todo.md"

get_name() {
  basename "$1" | tr . _ | tr '[:upper:]' '[:lower:]'
}

session_exists() {
  tmux has-session -t "=$1" 2>/dev/null
}

is_notes_path() {
  printf '%s\n' "$NOTES_PATH" | rg -qFx "$1"
}

create_session() {
  tmux new-session -ds "$1" -c "$2"
}

switch_to() {
  tmux switch-client -t "$1"
}

notify() {
  tmux display-message "$1"
}

open_notes() {
  tmux send-keys -t "$1" "${EDITOR:-nvim} $2/$NOTES_FILE" Enter
}

pick_dirs() {
  # shellcheck disable=SC2086
  fd . --max-depth 1 --type d --type l --follow $SESSION_DIRS 2>/dev/null | fzf --multi
}

ensure_session() {
  path="$1"
  name="$2"

  if session_exists "$name"; then
    return 0
  fi

  create_session "$name" "$path"
  is_notes_path "$path" && open_notes "$name" "$path"
  return 0
}

single() {
  path="$1"
  name="${2:-$(get_name "$path")}"
  ensure_session "$path" "$name"
  switch_to "$name"
}

multi() {
  paths=$(pick_dirs)
  [ -z "$paths" ] && exit 1

  tmp=$(mktemp)
  printf '%s\n' "$paths" | while IFS= read -r path; do
    [ -z "$path" ] && continue
    name=$(get_name "$path")
    ensure_session "$path" "$name"
    printf '%s' "$name" >"$tmp"
  done

  last=$(cat "$tmp")
  rm -f "$tmp"
  [ -n "$last" ] && switch_to "$last"
}

main() {
  [ -n "$1" ] && {
    single "$@"
    return
  }
  multi
}

main "$@"
