#!/usr/bin/env zsh

ZSH_CACHE_DIR="${ZDOTDIR:-$HOME/.zsh}/cache"

keys() {
  xev | awk -F'[ )]+' '/^KeyPress/ { a[NR+2] } NR in a { printf "%-3s %s\n", $5, $8 }'
}

dt() {
  rm -rf "$HOME/.local/share/Trash"
  printf "Trash dir was deleted"
}

rez() {
  . /home/bryant/.zshrc
}

tk() {
  if [ -z "$TMUX" ]; then
    tmux kill-server
  else
    ~/bin/tmux/remove-all "/home/$USER"
  fi

  cd "$HOME"
}

h() {
  if [ -z "$TMUX" ]; then
    printf "Not in a tmux session.\n" >&2
    return 1
  fi
  local tmux_current_pane_path tmux_current_session_path
  tmux_current_pane_path="$(tmux display-message -p '#{pane_current_path}')" || return 1
  tmux_current_session_path="$(tmux display-message -p '#{session_path}')" || return 1
  if [ "$tmux_current_pane_path" = "$tmux_current_session_path" ]; then
    tmux display-message "You are already in your session root directory"
    return 0
  fi
  cd "$tmux_current_session_path" || {
    tmux display-message "Error: Could not change to session root: $tmux_current_session_path"
    return 1
  }
}

# Shell functions for binds
clear-and-redisplay() {
  printf '\033[2J\033[3J\033[H'
  zle redisplay
}

copy-terminal-buffer() {
  echo "$BUFFER" | xclip -selection clipboard
  zle reset-prompt
}

smart-help() {
  local cmd
  cmd="${BUFFER%% *}"
  if [ -z "$cmd" ] || [ -z "$BUFFER" ]; then
    return
  fi
  if man -w "$cmd" >/dev/null 2>&1; then
    BUFFER="man $cmd"
    zle accept-line
  elif command -v "$cmd" >/dev/null 2>&1; then
    BUFFER="$cmd --help | less -F"
    zle accept-line
  else
    printf '\a'
  fi
}

y() {
  tmp="$(mktemp)"
  command lf -last-dir-path="$tmp" "$@"
  if [ -f "$tmp" ]; then
    dir="$(cat "$tmp")"
    rm -f "$tmp"
    if [ -d "$dir" ] && [ "$dir" != "$PWD" ]; then
      cd "$dir" || return
    fi
  fi
}

# OS-aware power management wrapper

smart_power() {
  local os_id="unknown"

  if [[ -f /etc/os-release ]]; then
    os_id=$(grep '^ID=' /etc/os-release | cut -d= -f2 | tr -d '"')
  fi

  if [[ "$os_id" == "artix" || "$os_id" == "void" ]]; then
    case "$1" in
    shutdown) loginctl poweroff ;;
    restart) loginctl reboot ;;
    suspend) loginctl suspend ;;
    *) echo "Usage: smart_power {shutdown|restart|suspend}" ;;
    esac
  else
    echo "Error: Unrecognized OS ($os_id). This script targets Artix and Void."
  fi
}

# Cache

zsh-cache-init() {
  local name=$1
  shift
  local cache_file="$ZSH_CACHE_DIR/$name.zsh"
  [[ -d $ZSH_CACHE_DIR ]] || mkdir -p "$ZSH_CACHE_DIR"
  if [[ ! -s $cache_file ]]; then
    "$@" >|"$cache_file" || return
    zcompile "$cache_file" 2>/dev/null
  fi
  source "$cache_file"
}

# Completion
zcompinit() {
  local dump="$ZSH_CACHE_DIR/zcompdump"
  [[ -d $ZSH_CACHE_DIR ]] || mkdir -p "$ZSH_CACHE_DIR"
  autoload -Uz compinit
  if [[ -s $dump ]]; then
    compinit -C -d "$dump"   # cache exists: trust it, skip security check, no regen
  else
    compinit -d "$dump"      # no cache: full init
    zcompile-dump
  fi
}

zcompile-dump() {
  local dump="$ZSH_CACHE_DIR/zcompdump"
  [[ -s $dump && (! -s $dump.zwc || $dump -nt $dump.zwc) ]] && zcompile "$dump"
}

zcompile-config() {
  local f
  for f in ~/.zshrc ~/.zsh/{aliases,functions,path,config,plugin}; do
    [[ -f $f && (! -f $f.zwc || $f -nt $f.zwc) ]] && zcompile "$f"
  done
}

# Clean
zclean() {
  local target_dir="${1:-$PWD}"
  if [[ ! -d "$target_dir" ]]; then
    echo "Directory not found: $target_dir" >&2
    return 1
  fi
  echo "Cleaning cache files in: $target_dir"
  if [[ -d "$target_dir/cache" ]]; then
    echo "Removing directory: $target_dir/cache"
    rm -rf "$target_dir/cache"
  fi
  local zwc_files=("$target_dir"/**/*.zwc(N))
  if ((${#zwc_files[@]} > 0)); then
    for f in "${zwc_files[@]}"; do
      echo "Removing file: $f"
      rm -f "$f"
    done
  else
    echo "No .zwc files found."
  fi
  echo "Done."
}
