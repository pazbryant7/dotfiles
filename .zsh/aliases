#!/usr/bin/env zsh

# weather
alias l="less"
alias weather='curl -s "wttr.in/Tecoh,Yucatan"'

# main
alias :q="exit"
alias wg="sudo wg"
alias sudo="sudo "
alias pass="gopass"
alias ff="fastfetch"
alias name="generate_name"
alias dh="rm ~/.history.db"
alias rbt="systemctl reboot"
alias xr="nvim ~/.Xresources"
alias c="xclip -selection clipboard"
alias fontcache="sudo fc-cache -f -v"
alias feh="feh -g 860x600 --scale-down"
alias p="xclip -selection clipboard -o"
alias calc="python -i -c 'import math, cmath; from math import *'"
alias rex="xrdb -remove && xrdb -merge ~/.Xresources && kill -USR1 \$(pidof st)"

#  nix
alias d='nix develop'
alias ngb='nix-store --gc'
alias nsn='env IN_NIX_SHELL=1 nix shell nixpkgs#nil nixpkgs#statix nixpkgs#nixfmt'
alias nss='env IN_NIX_SHELL=1 nix shell nixpkgs#bash-language-server nixpkgs#shfmt'

# zsh
alias zshe="nvim ~/.zshenv"
alias zshc="cd ~/.zsh && nvim config"
alias zsha="cd ~/.zsh && nvim  aliases"

# power managment
alias sp="smart_power suspend"
alias rbt="smart_power restart"
alias sht="smart_power shutdown"

# lazygit
alias lzg="lazygit"
alias lzd="lazydocker"

# btm
alias btm="btm --basic"

# tmux
alias ta="tmux attach"
alias tn="tmux new -s \$USER"
